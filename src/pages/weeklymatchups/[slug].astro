---
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const allMatchups = Object.values(import.meta.glob('../../content/*.md', { eager: true }));
  
  return allMatchups.map((matchup) => ({
    params: { slug: matchup.frontmatter.slug },
    props: { title: matchup.frontmatter.title }
  }))
}

const { slug } = Astro.params;
const { title } = Astro.props;
---

<BlogLayout>
  BLOG PAGE
</BlogLayout>